{
  "name": "api-explorer",
  "displayName": "Zerk: API testing in your editor",
  "description": "Zerk kills the friction between writing and testing your API. Zero-config: auto-discovers your running FastAPI/OpenAPI server's endpoints, fires requests, saves test cases, and smoke-tests - without leaving your editor.",
  "version": "0.9.0",
  "private": false,
  "publisher": "sahilrajpal",
  "author": "Sahil Rajpal",
  "preview": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sahilr05/zerk"
  },
  "bugs": {
    "url": "https://github.com/sahilr05/zerk/issues"
  },
  "icon": "resources/icons/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Testing",
    "Visualization"
  ],
  "keywords": [
    "api",
    "rest",
    "fastapi",
    "openapi",
    "swagger",
    "http",
    "client",
    "explorer",
    "api explorer",
    "api client",
    "smoke test",
    "testing"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Zerk",
      "properties": {
        "apiExplorer.openapiUrl": {
          "type": "string",
          "default": "http://localhost:8000/openapi.json",
          "description": "URL of the OpenAPI specification"
        }
      }
    },
    "commands": [
      {
        "command": "apiExplorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "apiExplorer.changeBaseUrl",
        "title": "Zerk: Change Base URL"
      },
      {
        "command": "apiExplorer.search",
        "title": "Search Endpoints",
        "icon": "$(search)"
      },
      {
        "command": "apiExplorer.clearSearch",
        "title": "Clear Search",
        "icon": "$(search-stop)"
      },
      {
        "command": "apiExplorer.groupByMethod",
        "title": "Group by Method",
        "icon": "$(list-unordered)"
      },
      {
        "command": "apiExplorer.groupByModule",
        "title": "Group by Module",
        "icon": "$(folder)"
      },
      {
        "command": "apiExplorer.filterByMethod",
        "title": "Filter by Method"
      },
      {
        "command": "apiExplorer.filterByModule",
        "title": "Filter by Module"
      },
      {
        "command": "apiExplorer.toggleSort",
        "title": "Toggle Sort Order"
      },
      {
        "command": "apiExplorer.filterAndSort",
        "title": "Filter Endpoints",
        "icon": "$(list-filter)"
      },
      {
        "command": "apiExplorer.clearHistory",
        "title": "Clear History",
        "icon": "$(trash)"
      },
      {
        "command": "apiExplorer.openConfig",
        "title": "Project Configuration",
        "icon": "$(gear)"
      },
      {
        "command": "apiExplorer.runAll",
        "title": "Run Smoke Test",
        "icon": "$(beaker)"
      },
      {
        "command": "apiExplorer.runModule",
        "title": "Run all in module",
        "icon": "$(beaker)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "api-explorer",
          "title": "Zerk",
          "icon": "resources/icons/icon.svg"
        }
      ]
    },
    "views": {
      "api-explorer": [
        {
          "id": "apiExplorer.endpoints",
          "name": "Endpoints"
        },
        {
          "id": "apiExplorer.history",
          "name": "History"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "apiExplorer.runModule",
          "when": "view == apiExplorer.endpoints && viewItem == moduleGroup",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "apiExplorer.search",
          "when": "view == apiExplorer.endpoints && !apiExplorer.searchActive",
          "group": "navigation@1"
        },
        {
          "command": "apiExplorer.clearSearch",
          "when": "view == apiExplorer.endpoints && apiExplorer.searchActive",
          "group": "navigation@1"
        },
        {
          "command": "apiExplorer.groupByMethod",
          "when": "view == apiExplorer.endpoints && apiExplorer.groupMode != 'method'",
          "group": "navigation@2"
        },
        {
          "command": "apiExplorer.groupByModule",
          "when": "view == apiExplorer.endpoints && apiExplorer.groupMode != 'module'",
          "group": "navigation@3"
        },
        {
          "command": "apiExplorer.filterAndSort",
          "when": "view == apiExplorer.endpoints",
          "group": "navigation@4"
        },
        {
          "command": "apiExplorer.runAll",
          "when": "view == apiExplorer.endpoints",
          "group": "navigation@5"
        },
        {
          "command": "apiExplorer.refresh",
          "when": "view == apiExplorer.endpoints",
          "group": "navigation@6"
        },
        {
          "command": "apiExplorer.openConfig",
          "when": "view == apiExplorer.endpoints",
          "group": "navigation@7"
        },
        {
          "command": "apiExplorer.clearHistory",
          "when": "view == apiExplorer.history",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "vscode:prepublish": "npm run clean && npm run compile && npm run bundle:mcp",
    "compile": "tsc -p ./",
    "bundle:mcp": "node esbuild.js --production",
    "watch": "tsc -watch -p ./",
    "clean": "rm -rf out",
    "lint": "tsc --noEmit",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.1",
    "typescript": "~5.8.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
